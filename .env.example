# Cardiotect Environment Configuration
# Copy this file to .env and edit as needed

# Path to your dataset directory
CARDIOTECT_DATASET_ROOT=C:\path\to\your\dataset

# Optional: Set to 'true' to enable GPU acceleration (requires CUDA)
CARDIOTECT_USE_GPU=true

# Optional: Set checkpoint path if not using default
CARDIOTECT_CHECKPOINT_PATH=outputs/checkpoints/best.ckpt